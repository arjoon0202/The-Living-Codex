---
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';
import '../styles/ambient.css';
import '../styles/glassmorphism.css';
import '../styles/animations.css';
import Sidebar from '../components/Sidebar.astro';

interface Props {
  title: string;
  ambientColor?: string;
  volume?: string;
  section?: string;
  backgroundImage?: string;
}

const {
  title,
  ambientColor = '#D4A843',
  volume = 'sovereign',
  section = '',
  backgroundImage = ''
} = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} — The Living Codex</title>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;900&family=Rajdhani:wght@300;400;500;600;700&family=Noto+Sans+JP:wght@300;400;500;700&display=swap" rel="stylesheet">
  <link rel="icon" type="image/png" href={`${base}/logo/favicon.png`} />
  <meta property="og:image" content={`${base}/logo/og-image.webp`} />
  <ViewTransitions />
</head>
<body data-volume={volume} data-section={section} style={`--ambient-color: ${ambientColor}`}>

  <a href="#main-content" class="skip-to-content">Skip to content</a>

  <!-- Layer 1-3: Background art system -->
  <div class="page-background">
    {backgroundImage && (
      <div class="page-background__image"
           style={`background-image: url('${backgroundImage}')`}></div>
    )}
    <div class="page-background__overlay"></div>
    <div class="page-background__tint"></div>
  </div>

  <!-- Layer 4: Existing ambient gradient -->
  <div class="ambient-bg"></div>

  <!-- Layer 4b: Hex particle animation -->
  <div class="hex-particles" id="hexParticles"></div>

  <!-- Mobile sidebar overlay -->
  <div class="sidebar-overlay" id="sidebarOverlay"></div>

  <div class="site-layout">
    <Sidebar currentVolume={volume} currentSection={section} />
    <main class="main-content" id="main-content">
      <slot />
    </main>
  </div>

  <script>
    // Hex particles
    const particleContainer = document.getElementById('hexParticles');
    if (particleContainer && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      for (let i = 0; i < 12; i++) {
        const p = document.createElement('div');
        p.className = 'hex-particle';
        p.style.left = Math.random() * 100 + '%';
        p.style.animationDuration = (15 + Math.random() * 20) + 's';
        p.style.animationDelay = Math.random() * 15 + 's';
        p.style.width = (4 + Math.random() * 4) + 'px';
        p.style.height = p.style.width;
        particleContainer.appendChild(p);
      }
    }

    // Mobile sidebar toggle
    const toggle = document.getElementById('sidebarToggle');
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebarOverlay');
    if (toggle && sidebar) {
      toggle.addEventListener('click', () => {
        sidebar.classList.toggle('open');
        overlay?.classList.toggle('visible');
      });
    }
  </script>
  <script src={`${import.meta.env.BASE_URL}/scripts/scroll-reveals.js`} defer></script>
</body>
</html>
