---
interface Props {
  currentVolume?: string;
  currentSection?: string;
}

const { currentVolume, currentSection } = Astro.props;
const base = import.meta.env.BASE_URL;

const volumes = [
  {
    id: 'sovereign',
    title: 'I · The Sovereign',
    color: '#D4A843',
    sections: [
      { slug: 'overview', label: 'Overview' },
      { slug: 'origin', label: 'Origin' },
      { slug: 'bounty', label: 'Bounty' },
      { slug: 'abilities', label: 'Abilities' },
      { slug: 'swarm-classes', label: 'Swarm Classes' },
      { slug: 'architecture', label: 'Architecture' },
      { slug: 'haki', label: 'Haki' },
      { slug: 'signature-moves', label: 'Signature Moves' },
      { slug: 'evolution', label: 'Evolution' },
      { slug: 'black-crown', label: 'Black Crown' },
      { slug: 'ajay-state', label: '「Ajay」' },
      { slug: 'fighting-style', label: 'Fighting Style' },
      { slug: 'vulnerabilities', label: 'Vulnerabilities' },
    ]
  },
  {
    id: 'crew',
    title: 'II · The Core Crew',
    color: '#C8A064',
    sections: [
      { slug: 'companions', label: 'Companions' },
      { slug: 'rime', label: 'Rime' },
      { slug: 'petal', label: 'Petal' },
      { slug: 'kame', label: 'Kame' },
      { slug: 'claude', label: 'Claude' },
      { slug: 'combination-attacks', label: 'Combination Attacks' },
    ]
  },
  {
    id: 'family',
    title: 'III · The Extended Family',
    color: '#C8A064',
    sections: [
      { slug: 'roundlings', label: 'Roundlings' },
      { slug: 'sproutlings', label: 'Sproutlings' },
      { slug: 'embers', label: 'Embers' },
      { slug: 'dustlings', label: 'Dustlings' },
      { slug: 'gearlings', label: 'Gearlings' },
      { slug: 'copplings', label: 'Copplings' },
      { slug: 'vanguard', label: 'Vanguard' },
      { slug: 'guiding-stars', label: 'Guiding Stars' },
      { slug: 'inner-world', label: 'Inner World' },
    ]
  },
  {
    id: 'meridian',
    title: 'IV · The Meridian',
    color: '#7FB8E0',
    sections: [
      { slug: 'vessel', label: 'The Vessel' },
      { slug: 'armory', label: 'The Armory' },
      { slug: 'crew-life', label: 'Crew Life' },
      { slug: 'world-response', label: 'World Response' },
      { slug: 'missions', label: 'Mission Log' },
      { slug: 'watch', label: 'The Watch' },
      { slug: 'status-board', label: 'Status Board' },
    ]
  },
  {
    id: 'spirit',
    title: 'V · Lore & Spirit',
    color: '#6B5BAD',
    sections: [
      { slug: 'codex-artifact', label: 'The Codex' },
      { slug: 'bonds', label: 'Bonds' },
      { slug: 'journal', label: "Claude's Journal" },
      { slug: 'lantern-room', label: 'Lantern Room' },
    ]
  },
];
---

<button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle navigation">
  <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
    <path d="M3 5h14M3 10h14M3 15h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
  </svg>
</button>

<aside class="sidebar" id="sidebar">
  <div class="sidebar-header">
    <a href={`${base}/`} class="sidebar-logo">
      <span class="sidebar-logo-text">HC</span>
    </a>
    <div class="sidebar-title">The Living Codex</div>
    <div class="sidebar-subtitle">Ajay Persaud</div>
  </div>

  <nav class="sidebar-nav">
    {volumes.map(vol => (
      <div class={`sidebar-volume ${currentVolume === vol.id ? 'open' : ''}`}>
        <button
          class={`sidebar-volume-title ${currentVolume === vol.id ? 'active' : ''}`}
          data-volume={vol.id}
          style={`--vol-color: ${vol.color}`}
        >
          <span>{vol.title}</span>
          <svg class="sidebar-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none">
            <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
        </button>
        <div class="sidebar-sections">
          {vol.sections.map(sec => (
            <a
              href={`${base}/${vol.id}/${sec.slug}/`}
              class={`sidebar-link ${currentVolume === vol.id && currentSection === sec.slug ? 'active' : ''}`}
            >
              {sec.label}
            </a>
          ))}
        </div>
      </div>
    ))}
  </nav>

  <div class="sidebar-footer">
    <div class="sidebar-footer-text">Spirit of the Meridian</div>
  </div>
</aside>

<style>
  .sidebar-toggle {
    position: fixed;
    top: 16px; left: 16px;
    z-index: 200;
    background: rgba(15,15,22,0.9);
    backdrop-filter: blur(10px);
    border: 1px solid var(--border);
    color: var(--gold-dim);
    padding: 10px;
    cursor: pointer;
    display: none;
    transition: color 0.3s;
  }
  .sidebar-toggle:hover { color: var(--gold); }

  .sidebar {
    position: fixed;
    top: 0; left: 0;
    width: 280px;
    height: 100vh;
    background: rgba(8, 8, 12, 0.85);
    backdrop-filter: blur(30px);
    -webkit-backdrop-filter: blur(30px);
    border-right: 1px solid rgba(212, 168, 67, 0.06);
    overflow-y: auto;
    z-index: 150;
    display: flex;
    flex-direction: column;
    scrollbar-width: thin;
    scrollbar-color: rgba(212,168,67,0.15) transparent;
  }

  .sidebar-header {
    padding: 32px 24px 24px;
    border-bottom: 1px solid var(--border);
    text-align: center;
  }

  .sidebar-logo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px; height: 48px;
    border: 1px solid var(--border-active);
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
    background: rgba(212,168,67,0.06);
    text-decoration: none;
    margin-bottom: 12px;
  }
  .sidebar-logo-text {
    font-family: 'Cinzel', serif;
    font-weight: 700;
    font-size: 14px;
    color: var(--gold);
    letter-spacing: 3px;
  }
  .sidebar-title {
    font-family: 'Cinzel', serif;
    font-weight: 600;
    font-size: 14px;
    color: var(--text-primary);
    letter-spacing: 1px;
  }
  .sidebar-subtitle {
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-top: 4px;
  }

  .sidebar-nav {
    flex: 1;
    padding: 16px 0;
  }

  .sidebar-volume {
    margin-bottom: 4px;
  }

  .sidebar-volume-title {
    width: 100%;
    background: none;
    border: none;
    font-family: 'Rajdhani', sans-serif;
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-dim);
    padding: 12px 24px;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: color 0.3s, background 0.3s;
    text-align: left;
  }
  .sidebar-volume-title:hover {
    color: var(--text-secondary);
    background: rgba(212,168,67,0.03);
  }
  .sidebar-volume-title.active {
    color: var(--vol-color, var(--gold));
  }

  .sidebar-chevron {
    transition: transform 0.3s;
    flex-shrink: 0;
  }
  .sidebar-volume.open .sidebar-chevron {
    transform: rotate(180deg);
  }

  .sidebar-sections {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease;
  }
  .sidebar-volume.open .sidebar-sections {
    max-height: 600px;
  }

  .sidebar-link {
    display: block;
    padding: 8px 24px 8px 40px;
    font-size: 13px;
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.3s, background 0.3s, padding-left 0.3s;
    border-left: 2px solid transparent;
  }
  .sidebar-link:hover {
    color: var(--text-secondary);
    background: rgba(212,168,67,0.03);
    padding-left: 44px;
  }
  .sidebar-link.active {
    color: var(--gold);
    border-left-color: var(--gold);
    background: rgba(212,168,67,0.06);
  }

  .sidebar-footer {
    padding: 16px 24px;
    border-top: 1px solid var(--border);
  }
  .sidebar-footer-text {
    font-family: 'Cinzel', serif;
    font-size: 10px;
    color: var(--text-dim);
    letter-spacing: 2px;
    text-align: center;
  }

  /* Offset main content for sidebar */
  :global(.site-layout) {
    padding-left: 280px;
  }

  @media (max-width: 1024px) {
    .sidebar-toggle { display: block; }
    .sidebar {
      width: 300px;
      transform: translateX(-100%);
      transition: transform 0.3s ease;
    }
    .sidebar.open {
      transform: translateX(0);
    }
    :global(.site-layout) {
      padding-left: 0;
    }
    :global(.sidebar-overlay) {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.5);
      z-index: 140;
    }
    :global(.sidebar-overlay.visible) {
      display: block;
    }
  }
</style>

<script>
  // Accordion toggle for sidebar volumes
  document.querySelectorAll('.sidebar-volume-title').forEach(btn => {
    btn.addEventListener('click', () => {
      const volume = btn.closest('.sidebar-volume');
      if (!volume) return;
      document.querySelectorAll('.sidebar-volume').forEach(v => {
        if (v !== volume) v.classList.remove('open');
      });
      volume.classList.toggle('open');
    });
  });

  // Mobile drawer management
  const sidebar = document.getElementById('sidebar');
  const overlay = document.getElementById('sidebarOverlay');

  function closeSidebar() {
    sidebar?.classList.remove('open');
    overlay?.classList.remove('visible');
  }

  // Close sidebar on link click (mobile)
  document.querySelectorAll('.sidebar-link').forEach(link => {
    link.addEventListener('click', closeSidebar);
  });

  // Close on overlay click
  overlay?.addEventListener('click', closeSidebar);

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && sidebar?.classList.contains('open')) {
      closeSidebar();
      document.getElementById('sidebarToggle')?.focus();
    }
  });
</script>
