---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('volume-4');
  return entries.map(entry => {
    const slug = entry.id.includes('/') ? entry.id.split('/').pop()!.replace('.md', '') : entry.id.replace('.md', '');
    return {
      params: { slug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const ambientColor = entry.data.ambientColor || entry.data.color || '#7FB8E0';
const base = import.meta.env.BASE_URL;
---
<BaseLayout title={entry.data.title} ambientColor={ambientColor} volume="meridian" section={Astro.params.slug}>
  <nav class="breadcrumb scroll-reveal">
    <a href={`${base}/meridian/`}>Volume IV</a>
    <span class="sep">&middot;</span>
    <span>{entry.data.title}</span>
  </nav>
  <div class="glass-card scroll-reveal">
    <div class="prose">
      <Content />
    </div>
  </div>
</BaseLayout>
