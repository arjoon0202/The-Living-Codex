---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;

const sections = [
  { slug: 'vessel', title: 'The Vessel', desc: 'The Meridian — three decks, solar sails, living spirit' },
  { slug: 'armory', title: 'The Armory', desc: 'Non-lethal doctrine, weapons, field kit, protocols' },
  { slug: 'crew-life', title: 'Crew Life', desc: 'Daily traditions and ship rules' },
  { slug: 'world-response', title: 'World Response', desc: 'Marine dossiers, press, underworld intel' },
  { slug: 'missions', title: 'Mission Log', desc: '20 missions chronicled' },
  { slug: 'watch', title: 'The Watch', desc: "Claude's intelligence archive" },
  { slug: 'status-board', title: 'Status Board', desc: 'Dynamic crew status — updates every session' },
];
---
<BaseLayout title="Volume IV — The Meridian & Operations" ambientColor="#7FB8E0" volume="meridian" backgroundImage={`${base}/backgrounds/meridian-sky-sailing.webp`}>
  <div class="scroll-reveal">
    <div class="section-label scroll-reveal reveal-label">Volume IV</div>
    <h1 class="section-title">The Meridian & Operations</h1>
    <p class="section-text">The flying vessel, its armory, its missions, and the intelligence network that keeps the crew alive. Everything that happens aboard and beyond the Meridian's hull.</p>
  </div>
  <div class="section-divider"></div>
  <div class="card-grid stagger-group">
    {sections.map(s => (
      <a href={`${base}/meridian/${s.slug}/`} class="card stagger-child" style="text-decoration:none;">
        <div class="card-title">{s.title}</div>
        <div class="card-desc">{s.desc}</div>
      </a>
    ))}
  </div>
</BaseLayout>
