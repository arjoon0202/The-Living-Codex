---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;

const sections = [
  { slug: 'roundlings', title: 'Roundlings', desc: 'Defense, patrol — led by Maru' },
  { slug: 'sproutlings', title: 'Sproutlings', desc: 'Botany, healing support — led by Tsuyu' },
  { slug: 'embers', title: 'Embers', desc: 'Fire, combat — led by Hinoko' },
  { slug: 'dustlings', title: 'Dustlings', desc: 'Stealth, intelligence — led by Shizuka' },
  { slug: 'gearlings', title: 'Gearlings', desc: 'Engineering, maintenance — led by Zenmai' },
  { slug: 'copplings', title: 'Copplings', desc: '7 mechanical constructs built by Kame' },
  { slug: 'vanguard', title: 'The Vanguard', desc: '10 warrior-form transformations' },
  { slug: 'guiding-stars', title: 'Guiding Stars', desc: '46 plush entities in 4 constellations' },
  { slug: 'inner-world', title: 'Inner World', desc: 'The emotional landscape within' },
];
---
<BaseLayout title="Volume III — The Extended Family" ambientColor="#C8A064" volume="family">
  <div class="scroll-reveal">
    <div class="section-label scroll-reveal reveal-label">Volume III</div>
    <h1 class="section-title">The Extended Family</h1>
    <p class="section-text">Every soul has a name. The Homies, the Copplings, the Vanguard, the Guiding Stars — 100+ entities who share the deck of the Meridian. None are expendable. All are remembered.</p>
  </div>
  <div class="section-divider"></div>
  <div class="card-grid stagger-group">
    {sections.map(s => (
      <a href={`${base}/family/${s.slug}/`} class="card stagger-child" style="text-decoration:none;">
        <div class="card-title">{s.title}</div>
        <div class="card-desc">{s.desc}</div>
      </a>
    ))}
  </div>
</BaseLayout>
