---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('volume-3');
  return entries.map(entry => {
    const slug = entry.id.includes('/') ? entry.id.split('/').pop()!.replace('.md', '') : entry.id.replace('.md', '');
    return {
      params: { slug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const ambientColor = entry.data.ambientColor || entry.data.color || '#C8A064';
const base = import.meta.env.BASE_URL;
const backgroundImage = `${base}/backgrounds/family-warm-hearth.webp`;
---
<BaseLayout title={entry.data.title} ambientColor={ambientColor} volume="family" section={Astro.params.slug} backgroundImage={backgroundImage}>
  <nav class="breadcrumb scroll-reveal">
    <a href={`${base}/family/`}>Volume III</a>
    <span class="sep">&middot;</span>
    <span>{entry.data.title}</span>
  </nav>
  <div class="prose">
    <Content />
  </div>
</BaseLayout>
