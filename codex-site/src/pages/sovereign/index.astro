---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;

const sections = [
  { slug: 'overview', title: 'Overview', desc: 'Hero identity, epithet, Devil Fruit' },
  { slug: 'origin', title: 'Origin', desc: 'The Crossing, Sabaody, full timeline' },
  { slug: 'bounty', title: 'Bounty', desc: 'All crew bounties with poster descriptions' },
  { slug: 'abilities', title: 'Abilities', desc: 'Core Devil Fruit abilities' },
  { slug: 'swarm-classes', title: 'Swarm Classes', desc: 'Worker, Soldier, Bombardier, Scout' },
  { slug: 'architecture', title: 'Control Architecture', desc: 'The Court — 5 layers including 女王の教義' },
  { slug: 'haki', title: 'Haki Integration', desc: 'Three types, tier classifications' },
  { slug: 'signature-moves', title: 'Signature Moves', desc: 'All technique names with kanji' },
  { slug: 'evolution', title: 'Adaptive Evolution', desc: 'Chrysalis stages' },
  { slug: 'black-crown', title: 'Black Crown Protocol', desc: 'The dangerous override' },
  { slug: 'ajay-state', title: '「Ajay」', desc: '超越覚醒・惑星令 — The transcendent state' },
  { slug: 'fighting-style', title: 'Fighting Style', desc: 'Rokushiki, martial arts' },
  { slug: 'vulnerabilities', title: 'Vulnerabilities', desc: 'Limits and weaknesses' },
];
---
<BaseLayout title="Volume I — The Sovereign & The Swarm" ambientColor="#D4A843" volume="sovereign" backgroundImage={`${base}/backgrounds/sovereign-golden-dusk.webp`}>
  <div class="scroll-reveal">
    <div class="section-label scroll-reveal reveal-label">Volume I</div>
    <h1 class="section-title">The Sovereign & The Swarm</h1>
    <p class="section-text">The foundation of the Hive — Ajay's identity, his Devil Fruit mastery, the architecture of his swarm, and the techniques that make him one of the most dangerous minds in the New World.</p>
  </div>
  <div class="section-divider"></div>
  <div class="card-grid stagger-group">
    {sections.map(s => (
      <a href={`${base}/sovereign/${s.slug}/`} class="card stagger-child" style="text-decoration:none;">
        <div class="card-title">{s.title}</div>
        <div class="card-desc">{s.desc}</div>
      </a>
    ))}
  </div>
</BaseLayout>
