---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('volume-1');
  return entries.map(entry => {
    // Handle nested paths like arsenal/abilities -> abilities
    const slug = entry.id.includes('/') ? entry.id.split('/').pop()!.replace('.md', '') : entry.id.replace('.md', '');
    return {
      params: { slug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const ambientColor = entry.data.ambientColor || entry.data.color || '#D4A843';
const base = import.meta.env.BASE_URL;
const slug = Astro.params.slug;
const cardVariant = slug === 'black-crown' ? 'glass-card--danger' : slug === 'ajay-state' ? 'glass-card--transcendent' : '';
const cardGlow = slug === 'black-crown' ? 'danger' : slug === 'ajay-state' ? 'transcendent' : undefined;
const bgMap: Record<string, string> = {
  'black-crown': `${base}/backgrounds/black-crown-storm.webp`,
  'ajay-state': `${base}/backgrounds/transcendent-nebula.webp`,
};
const backgroundImage = bgMap[slug as string] || `${base}/backgrounds/sovereign-golden-dusk.webp`;
---
<BaseLayout title={entry.data.title} ambientColor={ambientColor} volume="sovereign" section={slug} backgroundImage={backgroundImage}>
  <nav class="breadcrumb scroll-reveal">
    <a href={`${base}/sovereign/`}>Volume I</a>
    <span class="sep">&middot;</span>
    <span>{entry.data.title}</span>
  </nav>
  <div class="prose">
    <Content />
  </div>
</BaseLayout>
