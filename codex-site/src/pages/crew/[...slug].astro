---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('volume-2');

  const topLevel = entries.filter(e => !e.id.includes('/'));
  const topLevelBases = new Set(topLevel.map(e => e.id.replace('.md', '')));

  // Nested entries without a matching hub file get their own routes
  const standaloneNested = entries.filter(e => {
    if (!e.id.includes('/')) return false;
    const parentDir = e.id.split('/')[0];
    return !topLevelBases.has(parentDir);
  });

  const routeEntries = [...topLevel, ...standaloneNested];

  return routeEntries.map(entry => {
    const slug = entry.id.includes('/')
      ? entry.id.split('/').pop()!.replace('.md', '')
      : entry.id.replace('.md', '');
    return {
      params: { slug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// For hub entries, fetch and render child content inline
const allEntries = await getCollection('volume-2');
const entryBase = entry.id.replace('.md', '');
const children = allEntries
  .filter(e => e.id.startsWith(entryBase + '/'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const renderedChildren: Array<{ title: string; Content: any }> = [];
for (const child of children) {
  const { Content: CC } = await child.render();
  renderedChildren.push({ title: child.data.title, Content: CC });
}

const ambientColor = entry.data.ambientColor || entry.data.color || '#C8A064';
const base = import.meta.env.BASE_URL;
const slug = Astro.params.slug;
const characterVariant = slug === 'rime' ? 'glass-card--rime' : slug === 'petal' ? 'glass-card--petal' : slug === 'kame' ? 'glass-card--kame' : '';
const bgMap: Record<string, string> = {
  'rime': `${base}/backgrounds/rime-volcanic-steam.webp`,
  'petal': `${base}/backgrounds/petal-ancient-forest.webp`,
  'kame': `${base}/backgrounds/kame-ocean-depths.webp`,
};
const backgroundImage = bgMap[slug as string] || `${base}/backgrounds/sovereign-golden-dusk.webp`;
---
<BaseLayout title={entry.data.title} ambientColor={ambientColor} volume="crew" section={slug} backgroundImage={backgroundImage}>
  <nav class="breadcrumb scroll-reveal">
    <a href={`${base}/crew/`}>Volume II</a>
    <span class="sep">&middot;</span>
    <span>{entry.data.title}</span>
  </nav>
  <div class="prose">
    <Content />
    {renderedChildren.map(({ Content: ChildContent }) => (
      <section class="sub-section">
        <ChildContent />
      </section>
    ))}
  </div>
</BaseLayout>
