---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('volume-2');
  return entries.map(entry => {
    const slug = entry.id.includes('/') ? entry.id.split('/').pop()!.replace('.md', '') : entry.id.replace('.md', '');
    return {
      params: { slug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const ambientColor = entry.data.ambientColor || entry.data.color || '#C8A064';
const base = import.meta.env.BASE_URL;
const slug = Astro.params.slug;
const characterVariant = slug === 'rime' ? 'glass-card--rime' : slug === 'petal' ? 'glass-card--petal' : slug === 'kame' ? 'glass-card--kame' : '';
---
<BaseLayout title={entry.data.title} ambientColor={ambientColor} volume="crew" section={slug}>
  <nav class="breadcrumb scroll-reveal">
    <a href={`${base}/crew/`}>Volume II</a>
    <span class="sep">&middot;</span>
    <span>{entry.data.title}</span>
  </nav>
  <div class={`glass-card scroll-reveal ${characterVariant}`}>
    <div class="prose">
      <Content />
    </div>
  </div>
</BaseLayout>
