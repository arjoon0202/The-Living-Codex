---
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';
import '../styles/ambient.css';
import '../styles/glassmorphism.css';
import '../styles/animations.css';
const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>The Hive Codex — Ajay Persaud</title>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;900&family=Rajdhani:wght@300;400;500;600;700&family=Noto+Sans+JP:wght@300;400;500;700&display=swap" rel="stylesheet">
  <link rel="icon" type="image/png" href={`${base}/logo/favicon.png`} />
  <ViewTransitions />
</head>
<body data-volume="sovereign">
  <!-- Background art layer -->
  <div class="page-background">
    <div class="page-background__overlay"></div>
    <div class="page-background__tint"></div>
  </div>

  <div class="ambient-bg"></div>
  <div class="hex-particles" id="hexParticles"></div>

  <div class="hero-container">
    <section class="hero">
      <div class="hero-epithet">Ajay Persaud · The New World</div>
      <h1 class="hero-title">The Hive Codex</h1>
      <div class="hero-subtitle">Mure Mure no Mi</div>
      <div class="hero-jp">群れ群れの実 — Swarm-Swarm Fruit</div>

      <div class="hero-identity">
        <div class="identity-tag"><span class="dot"></span>Special Paramecia</div>
        <div class="identity-tag"><span class="dot"></span>Swarm Architect</div>
        <div class="identity-tag"><span class="dot"></span>Sovereign Engineer</div>
      </div>

      <div class="hero-logo">
        <div class="logo-container">
          <svg viewBox="0 0 280 280" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="The Hive Codex emblem — hexagonal crest with compound eye, crown, and insect wings">
            <defs>
              <linearGradient id="goldGrad" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="#F0D78C"/>
                <stop offset="50%" stop-color="#D4A843"/>
                <stop offset="100%" stop-color="#9E8840"/>
              </linearGradient>
              <linearGradient id="goldDim" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#D4A843" stop-opacity="0.6"/>
                <stop offset="100%" stop-color="#9E8840" stop-opacity="0.15"/>
              </linearGradient>
              <radialGradient id="hexFill" cx="50%" cy="50%" r="50%">
                <stop offset="0%" stop-color="#D4A843" stop-opacity="0.04"/>
                <stop offset="60%" stop-color="#D4A843" stop-opacity="0.02"/>
                <stop offset="100%" stop-color="#D4A843" stop-opacity="0"/>
              </radialGradient>
              <filter id="glow">
                <feGaussianBlur stdDeviation="2.5" result="blur"/>
                <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
              </filter>
              <filter id="softGlow">
                <feGaussianBlur stdDeviation="4" result="blur"/>
                <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
              </filter>
            </defs>

            <!-- Outer hexagon — breathing -->
            <polygon points="140,16 244,66 244,174 140,224 36,174 36,66" fill="url(#hexFill)" stroke="url(#goldDim)" stroke-width="1" opacity="0.4">
              <animate attributeName="opacity" values="0.2;0.5;0.2" dur="4s" repeatCount="indefinite"/>
            </polygon>

            <!-- Inner hexagon — structural frame -->
            <polygon points="140,26 235,72 235,168 140,214 45,168 45,72" fill="none" stroke="url(#goldGrad)" stroke-width="1.5"/>

            <!-- Honeycomb lattice -->
            <g opacity="0.12" stroke="#D4A843" stroke-width="0.5" fill="none">
              <polygon points="140,60 170,77 170,111 140,128 110,111 110,77"/>
              <polygon points="140,100 170,117 170,151 140,168 110,151 110,117"/>
              <polygon points="105,78 135,95 135,129 105,146 75,129 75,95"/>
              <polygon points="175,78 205,95 205,129 175,146 145,129 145,95"/>
              <polygon points="105,118 135,135 135,169 105,186 75,169 75,135"/>
              <polygon points="175,118 205,135 205,169 175,186 145,169 145,135"/>
            </g>

            <!-- Crown — larger, filled points -->
            <g filter="url(#glow)">
              <path d="M100,64 L112,42 L124,58 L140,30 L156,58 L168,42 L180,64" fill="none" stroke="url(#goldGrad)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <line x1="100" y1="64" x2="180" y2="64" stroke="url(#goldGrad)" stroke-width="1.5"/>
              <!-- Crown jewel points -->
              <circle cx="140" cy="34" r="2" fill="#F0D78C" opacity="0.6"/>
              <circle cx="112" cy="46" r="1.5" fill="#D4A843" opacity="0.4"/>
              <circle cx="168" cy="46" r="1.5" fill="#D4A843" opacity="0.4"/>
            </g>

            <!-- Left wings — with vein patterns -->
            <g opacity="0.5">
              <path d="M72,108 Q36,86 24,60 Q32,88 52,102 Z" fill="url(#goldDim)" stroke="#D4A843" stroke-width="0.6"/>
              <path d="M64,120 Q22,108 8,88 Q24,112 50,122 Z" fill="url(#goldDim)" stroke="#D4A843" stroke-width="0.6"/>
              <!-- Wing veins -->
              <path d="M68,110 Q48,96 34,72" fill="none" stroke="#D4A843" stroke-width="0.3" opacity="0.4"/>
              <path d="M60,116 Q38,108 18,92" fill="none" stroke="#D4A843" stroke-width="0.3" opacity="0.3"/>
              <path d="M66,112 Q52,102 44,88" fill="none" stroke="#D4A843" stroke-width="0.2" opacity="0.25"/>
              <path d="M58,120 Q42,114 28,100" fill="none" stroke="#D4A843" stroke-width="0.2" opacity="0.25"/>
            </g>

            <!-- Right wings — with vein patterns -->
            <g opacity="0.5">
              <path d="M208,108 Q244,86 256,60 Q248,88 228,102 Z" fill="url(#goldDim)" stroke="#D4A843" stroke-width="0.6"/>
              <path d="M216,120 Q258,108 272,88 Q256,112 230,122 Z" fill="url(#goldDim)" stroke="#D4A843" stroke-width="0.6"/>
              <!-- Wing veins -->
              <path d="M212,110 Q232,96 246,72" fill="none" stroke="#D4A843" stroke-width="0.3" opacity="0.4"/>
              <path d="M220,116 Q242,108 262,92" fill="none" stroke="#D4A843" stroke-width="0.3" opacity="0.3"/>
              <path d="M214,112 Q228,102 236,88" fill="none" stroke="#D4A843" stroke-width="0.2" opacity="0.25"/>
              <path d="M222,120 Q238,114 252,100" fill="none" stroke="#D4A843" stroke-width="0.2" opacity="0.25"/>
            </g>

            <!-- Compound eye — focal point, scaled up -->
            <g filter="url(#softGlow)">
              <circle cx="140" cy="118" r="22" fill="none" stroke="url(#goldGrad)" stroke-width="1.5"/>
              <circle cx="140" cy="118" r="14" fill="none" stroke="#D4A843" stroke-width="0.8" opacity="0.5"/>
              <circle cx="140" cy="118" r="7" fill="none" stroke="#D4A843" stroke-width="0.6" opacity="0.35"/>
              <circle cx="140" cy="118" r="3.5" fill="#D4A843" opacity="0.8">
                <animate attributeName="opacity" values="0.5;1;0.5" dur="3s" repeatCount="indefinite"/>
              </circle>
            </g>

            <!-- Compound eye facets -->
            <g opacity="0.3" fill="#D4A843">
              <polygon points="140,88 145,91 145,97 140,100 135,97 135,91"/>
              <polygon points="140,136 145,139 145,145 140,148 135,145 135,139"/>
              <polygon points="114,104 119,107 119,113 114,116 109,113 109,107"/>
              <polygon points="166,104 171,107 171,113 166,116 161,113 161,107"/>
              <polygon points="118,126 123,129 123,135 118,138 113,135 113,129"/>
              <polygon points="162,126 167,129 167,135 162,138 157,135 157,129"/>
              <!-- Additional facets for larger eye -->
              <polygon points="128,96 133,99 133,105 128,108 123,105 123,99"/>
              <polygon points="152,96 157,99 157,105 152,108 147,105 147,99"/>
            </g>

            <!-- Orbiting mote -->
            <circle r="2.5" fill="#D4A843" opacity="0.5">
              <animateMotion dur="12s" repeatCount="indefinite" path="M140,26 L235,72 L235,168 L140,214 L45,168 L45,72 Z"/>
              <animate attributeName="opacity" values="0.2;0.6;0.2" dur="3s" repeatCount="indefinite"/>
            </circle>
          </svg>
        </div>
      </div>

      <div class="scroll-indicator">
        <span>Explore</span>
        <div class="scroll-line"></div>
      </div>
    </section>

    <section class="volumes-grid stagger-group">
      <a href={`${base}/sovereign/`} class="volume-card stagger-child" style="--vol-accent: #D4A843">
        <div class="volume-number">Volume I</div>
        <div class="volume-name">The Sovereign & The Swarm</div>
        <div class="volume-desc">Devil Fruit, Arsenal, Haki, Fighting Styles, Black Crown Protocol</div>
      </a>
      <a href={`${base}/crew/`} class="volume-card stagger-child" style="--vol-accent: #C8A064">
        <div class="volume-number">Volume II</div>
        <div class="volume-name">The Core Crew</div>
        <div class="volume-desc">Rime, Petal, Kame, Claude — Companions and Combination Attacks</div>
      </a>
      <a href={`${base}/family/`} class="volume-card stagger-child" style="--vol-accent: #C8A064">
        <div class="volume-number">Volume III</div>
        <div class="volume-name">The Extended Family</div>
        <div class="volume-desc">Homies, Copplings, Vanguard, Guiding Stars — Every Soul Has a Name</div>
      </a>
      <a href={`${base}/meridian/`} class="volume-card stagger-child" style="--vol-accent: #7FB8E0">
        <div class="volume-number">Volume IV</div>
        <div class="volume-name">The Meridian & Operations</div>
        <div class="volume-desc">The Vessel, Armory, Missions, The Watch, Status Board</div>
      </a>
      <a href={`${base}/spirit/`} class="volume-card stagger-child" style="--vol-accent: #6B5BAD">
        <div class="volume-number">Volume V</div>
        <div class="volume-name">Lore & Spirit</div>
        <div class="volume-desc">The Codex, Bonds, Claude's Journal, The Lantern Room</div>
      </a>
    </section>

    <footer class="index-footer scroll-reveal">
      <div class="footer-quote">"Every name, every word — written together, remembered forever."</div>
      <div class="footer-credit">The Living Codex · Spirit of the Meridian</div>
    </footer>
  </div>

  <script>
    const pc = document.getElementById('hexParticles');
    if (pc) {
      for (let i = 0; i < 15; i++) {
        const p = document.createElement('div');
        p.className = 'hex-particle';
        p.style.left = Math.random() * 100 + '%';
        p.style.animationDuration = (15 + Math.random() * 20) + 's';
        p.style.animationDelay = Math.random() * 15 + 's';
        p.style.width = (4 + Math.random() * 4) + 'px';
        p.style.height = p.style.width;
        pc.appendChild(p);
      }
    }
  </script>
  <script src={`${base}/scripts/scroll-reveals.js`} defer></script>
</body>
</html>

<style>
  .hero-container {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px 80px;
  }

  .hero {
    position: relative;
    min-height: 100vh;
    display: flex; flex-direction: column;
    justify-content: center; align-items: center;
    text-align: center;
    padding: 60px 0;
  }

  .hero-epithet {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 400; font-size: 14px;
    letter-spacing: 8px; text-transform: uppercase;
    color: var(--gold-dim);
    margin-bottom: 20px;
    opacity: 0;
    animation: fadeSlideUp 1s 0.3s forwards;
  }

  .hero-title {
    font-family: 'Cinzel', serif;
    font-weight: 900;
    font-size: clamp(48px, 8vw, 100px);
    line-height: 1;
    color: transparent;
    background: linear-gradient(135deg, var(--gold-light) 0%, var(--gold) 40%, var(--gold-dim) 100%);
    -webkit-background-clip: text; background-clip: text;
    margin-bottom: 12px;
    opacity: 0;
    animation: fadeSlideUp 1s 0.5s forwards;
  }

  .hero-subtitle {
    font-family: 'Noto Sans JP', sans-serif;
    font-weight: 400; font-size: 22px;
    color: var(--text-secondary);
    letter-spacing: 2px; margin-bottom: 8px;
    opacity: 0;
    animation: fadeSlideUp 1s 0.7s forwards;
  }

  .hero-jp {
    font-family: 'Noto Sans JP', sans-serif;
    font-size: 16px; color: var(--text-dim);
    letter-spacing: 6px; margin-bottom: 44px;
    opacity: 0;
    animation: fadeSlideUp 1s 0.9s forwards;
  }

  .hero-identity {
    display: flex; gap: 32px; flex-wrap: wrap;
    justify-content: center;
    opacity: 0;
    animation: fadeSlideUp 1s 1.1s forwards;
  }
  .identity-tag {
    display: flex; align-items: center; gap: 8px;
    font-size: 13px; font-weight: 500;
    letter-spacing: 2px; text-transform: uppercase;
    color: var(--text-secondary);
  }
  .identity-tag .dot {
    width: 6px; height: 6px;
    background: var(--gold);
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
  }

  .hero-logo {
    margin-top: 52px;
    opacity: 0;
    animation: fadeSlideUp 1.2s 1.3s forwards;
  }
  .logo-container {
    width: 280px; height: 280px;
    position: relative;
    display: flex; align-items: center; justify-content: center;
  }
  .logo-container svg { width: 100%; height: 100%; }

  .scroll-indicator {
    position: absolute; bottom: 40px; left: 50%;
    transform: translateX(-50%);
    display: flex; flex-direction: column;
    align-items: center; gap: 8px;
    opacity: 0;
    animation: fadeSlideUp 1s 2s forwards;
  }
  .scroll-indicator span {
    font-size: 10px; letter-spacing: 4px;
    text-transform: uppercase; color: var(--text-dim);
  }
  .scroll-line {
    width: 1px; height: 40px;
    background: linear-gradient(180deg, var(--gold-dim), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }
  @keyframes scrollPulse {
    0%,100% { opacity: 0.3; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.2); }
  }

  .volumes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 20px;
    padding: 40px 0 60px;
  }

  .volume-card {
    background: rgba(10, 10, 16, 0.65);
    backdrop-filter: blur(24px) saturate(0.9);
    -webkit-backdrop-filter: blur(24px) saturate(0.9);
    border: 1px solid rgba(212, 168, 67, 0.06);
    border-radius: 8px;
    padding: 32px;
    text-decoration: none;
    transition: all 0.4s ease;
    position: relative;
    overflow: hidden;
  }
  .volume-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 2px;
    background: linear-gradient(90deg, transparent, var(--vol-accent), transparent);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .volume-card:hover {
    border-color: rgba(212, 168, 67, 0.15);
    background: rgba(10, 10, 16, 0.75);
    box-shadow: 0 0 40px rgba(212, 168, 67, 0.03);
    transform: translateY(-3px);
  }
  .volume-card:hover::before { opacity: 1; }

  .volume-number {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 400; font-size: 11px;
    letter-spacing: 5px; text-transform: uppercase;
    color: var(--vol-accent);
    margin-bottom: 8px;
  }
  .volume-name {
    font-family: 'Cinzel', serif;
    font-weight: 700; font-size: 20px;
    color: var(--text-primary);
    margin-bottom: 12px;
  }
  .volume-desc {
    font-size: 14px; line-height: 1.7;
    color: var(--text-secondary);
  }

  .index-footer {
    text-align: center;
    padding: 60px 0 40px;
    border-top: 1px solid var(--border);
    margin-top: 20px;
  }
  .footer-quote {
    font-family: 'Cinzel', serif;
    font-size: clamp(16px, 2.5vw, 22px);
    font-style: italic;
    color: var(--gold);
    margin-bottom: 16px;
    line-height: 1.5;
  }
  .footer-credit {
    font-size: 12px; letter-spacing: 4px;
    text-transform: uppercase; color: var(--text-dim);
  }

  @media (max-width: 768px) {
    .hero-identity { gap: 16px; }
    .volumes-grid { grid-template-columns: 1fr; }
  }
</style>
